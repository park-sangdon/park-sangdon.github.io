# Backend only. Do not expose this in the frontend bundle.
GEMINI_API_KEY="your_gemini_api_key"

# Recommended default for a site chatbot.
# As of 2026-04-08, Google AI Studio publicly lists gemini-3-flash-preview.
GEMINI_MODEL="gemini-3-flash-preview"

# Frontend origin allowed to call the chat server.
# Use your local Vite URL in development and your public site URL in production.
FRONTEND_ORIGIN="http://localhost:3000"

# Public frontend setting. Safe to expose.
# For local dev you can keep the default /api/chat because Vite proxies to the local server.
# For GitHub Pages production, point this to your deployed backend URL.
VITE_CHAT_API_URL="/api/chat"
